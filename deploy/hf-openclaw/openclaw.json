{
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18798,
    "auth": {
      "mode": "none"
    },
    "controlUi": {
      "allowedOrigins": [
        "https://dongli-meituan-ai-hackathon.hf.space",
        "https://huanjia.eu.cc",
        "http://127.0.0.1:18798",
        "http://localhost:18798"
      ]
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        }
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/workspace/.openclaw/workspace",
      "model": {
        "primary": "longcat/${LONGCAT_CHAT_MODEL}"
      }
    }
  },
  "models": {
    "providers": {
      "longcat": {
        "baseUrl": "https://api.longcat.chat/openai",
        "apiKey": "${LONGCAT_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "${LONGCAT_CHAT_MODEL}",
            "name": "${LONGCAT_CHAT_MODEL}",
            "api": "openai-completions",
            "input": ["text"],
            "contextWindow": 65536,
            "maxTokens": 4096
          }
        ]
      }
    }
  },
  "tools": {
    "profile": "minimal"
  }
}

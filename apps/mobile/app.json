{
  "expo": {
    "name": "焕甲",
    "slug": "nailtry-ai",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/app/icon.png",
    "splash": {
      "image": "./assets/app/opening.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nailtry.ai",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "焕甲需要使用你的位置来展示附近的美甲店。"
      }
    },
    "android": {
      "package": "com.nailtry.ai",
      "adaptiveIcon": {
        "foregroundImage": "./assets/app/icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/app/icon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-media-library",
      "@react-native-community/datetimepicker",
      [
        "expo-splash-screen",
        {
          "image": "./assets/app/opening.png",
          "imageWidth": 360,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "9ef5178e-485f-4f9c-a214-f8d4abcf2a40"
      }
    },
    "owner": "hedongli"
  }
}

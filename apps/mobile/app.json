{
  "expo": {
    "name": "焕甲",
    "slug": "nailtry-ai",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#fff4ed"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nailtry.ai",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "焕甲需要使用你的位置来展示附近的美甲店。"
      }
    },
    "android": {
      "package": "com.nailtry.ai",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-secure-store",
      "expo-media-library",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "nailtry-ai"
      }
    }
  }
}
